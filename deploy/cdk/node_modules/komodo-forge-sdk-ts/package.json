{
  "name": "@komodo-forge-sdk/typescript",
  "version": "0.4.0",
  "description": "An internal library for Komodo APIs built using Node",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "komodo",
    "forge",
    "sdk",
    "typescript",
    "node",
    "javascript",
    "client",
    "api",
    "shared"
  ],
  "author": "Komodo Future Solutions",
  "license": "ISC",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "pnpm run clean && pnpm run build",
    "fresh": "rm -rf node_modules && pnpm update --latest && pnpm install",
    "update": "pnpm update --latest && pnpm install",
    "prepublishOnly": "pnpm run rebuild",
    "release": "bash scripts/release.sh",
    "format": "biome format --write src/",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false src/",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.6.0",
    "fast-redact": "^3.5.0",
    "globals": "^17.6.0",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/fast-redact": "^3.0.4",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "oxlint": "^1.70.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./api/*": {
      "types": "./dist/api/*/index.d.ts",
      "import": "./dist/api/*/index.js"
    },
    "./cdk": {
      "types": "./dist/deploy/cdk/index.d.ts",
      "import": "./dist/deploy/cdk/index.js"
    },
    "./cdk/*": {
      "types": "./dist/deploy/cdk/*/index.d.ts",
      "import": "./dist/deploy/cdk/*/index.js"
    },
    "./cdk/constants": {
      "types": "./dist/deploy/cdk/constants.d.ts",
      "import": "./dist/deploy/cdk/constants.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./client/*": {
      "types": "./dist/client/*/index.d.ts",
      "import": "./dist/client/*/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./shared/*": {
      "types": "./dist/shared/*/index.d.ts",
      "import": "./dist/shared/*/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
